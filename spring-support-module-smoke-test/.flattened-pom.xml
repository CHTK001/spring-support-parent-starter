  <description>Dedicated Spring Boot smoke-test app for validating spring-support-parent-starter modules one by one.</description>
  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0</url>
      <distribution>repo</distribution>
    </license>
  </licenses>
  <properties>
    <smoke.swagger.enable>false</smoke.swagger.enable>
    <smoke.target.module>base</smoke.target.module>
  </properties>
