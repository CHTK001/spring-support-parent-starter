    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
      </plugin>
      <plugin>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <systemPropertyVariables>
            <smoke.target.module>${smoke.target.module}</smoke.target.module>
            <smoke.sql.init.mode>${smoke.sql.init.mode}</smoke.sql.init.mode>
            <smoke.sql.init.schema-locations>${smoke.sql.init.schema-locations}</smoke.sql.init.schema-locations>
            <smoke.sql.init.data-locations>${smoke.sql.init.data-locations}</smoke.sql.init.data-locations>
            <smoke.swagger.enable>${smoke.swagger.enable}</smoke.swagger.enable>
            <smoke.proxy.enable>${smoke.proxy.enable}</smoke.proxy.enable>
            <smoke.proxy.auto-restart-running>${smoke.proxy.auto-restart-running}</smoke.proxy.auto-restart-running>
          </systemPropertyVariables>
        </configuration>
      </plugin>
    </plugins>
  </build>
